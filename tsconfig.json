{
	"compilerOptions": {
		"lib": ["ESNext"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"target": "ES2022",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"noEmit": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["src/**/*.ts", "frontends/config.ts", "e2e/**/*.ts"],
	"exclude": ["e2e/playwright/**/*.ts"]
}
